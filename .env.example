# Gemini API Key (Required for server.js)
API_KEY=your_gemini_api_key_here

# Gemini API Key (Alias used in some guides)
GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram API Key (Required for test-deepgram.js)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# DeepL API Key (Required for standard translations)
DEEPL_API_KEY=your_deepl_api_key_here

# Backend URL (Used by Vite frontend, defaults to localhost:8080)
VITE_BACKEND_URL=ws://localhost:8080

# Server Port (Optional)
PORT=8080

# --- Local AI (Ollama) Settings ---
# Set to 'true' to use a local Ollama model instead of Gemini/DeepL for translation
ENABLE_LOCAL_AI=false
# Ollama model name (e.g., phi4, llama3, gemma2)
OLLAMA_MODEL=phi4
# Ollama API endpoint
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_API_KEY=your_secret_key_for_hybrid_mode
