# Gemini API Key (Required for server.js)
API_KEY=your_gemini_api_key_here

# Gemini API Key (Alias used in some guides)
GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram API Key (Required for test-deepgram.js)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# DeepL API Key (Required for standard translations)
DEEPL_API_KEY=your_deepl_api_key_here

# Backend URL (Used by Vite frontend)
# For Vercel + VM deployment: wss://your-tunnel-url.trycloudflare.com
# For local dev: ws://localhost:3001
VITE_BACKEND_URL=wss://your-tunnel-url.trycloudflare.com

# Server Port
PORT=3001

# --- Local AI (Ollama) Settings ---
# Set to 'true' to use Ollama on the VM instead of Gemini/DeepL
ENABLE_LOCAL_AI=true
# Ollama model name (e.g., gemma2:2b, phi4-mini, llama3.1)
# Note: 'gemma2:2b' is recommended for Intel Macs (like MacBook Pro 2018) for speed.
OLLAMA_MODEL=gemma2:2b
# Ollama API endpoint
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_API_KEY=your_secret_key_for_hybrid_mode
